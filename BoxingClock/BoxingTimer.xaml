<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:BoxingClock.Views"
             xmlns:admob="clr-namespace:Plugin.MauiMTAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             x:Class="BoxingClock.BoxingTimer">

    <Grid x:Name="pagelayout" 
          RowDefinitions="Auto,*"
          Background="Black"
          SizeChanged="Handle_SizeChanged">
        
        <!--ad space-->
        <admob:MTAdView 
                   Grid.Row="0"
                   Grid.ColumnSpan="3"
                   HeightRequest="50"
                   HorizontalOptions="Fill"
                   VerticalOptions="End"
                   IsVisible="True"
                   AdsId="ca-app-pub-3940256099942544/6300978111"/>


            <!--timer in ring layout-->
        <AbsoluteLayout Grid.Row="1" x:Name="timerlayout" >
            <StackLayout AbsoluteLayout.LayoutFlags="PositionProportional"
                         AbsoluteLayout.LayoutBounds="0.5,0.15,AutoSize,AutoSize">

                <Image x:Name="bsblogo" Source="bsb.png">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="BSBtapped"/>
                    </Image.GestureRecognizers> 
                </Image>
                <!-- social media/web icons and links -->
                <StackLayout x:Name="icons"
                             Orientation="Horizontal"
                             HorizontalOptions="Center"
                             VerticalOptions="End"
                             Spacing="10"
                             Opacity="0"
                             IsEnabled="False"
                             Margin="0,-10,0,0">
                    <Image x:Name="igLogo" Source="ig.png"
                           HorizontalOptions="Center"
                           VerticalOptions="End"
                           WidthRequest="35" >
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="igTapped"/>
                        </Image.GestureRecognizers>
                    </Image>

                    <Image x:Name="fbLogo" Source="fb.png"
                           HorizontalOptions="Center"
                           VerticalOptions="End"
                           WidthRequest="35" >
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="fbTapped"/>
                        </Image.GestureRecognizers>
                    </Image>
                    <Image x:Name="webLogo" Source="web.png"
                           HorizontalOptions="Center"
                           VerticalOptions="End"
                           WidthRequest="35" >
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="webTapped"/>
                        </Image.GestureRecognizers>
                    </Image>    

                </StackLayout>
            </StackLayout>
            <Image x:Name="topLeftLogo" Style="{StaticResource CornerLogoStyle}"
                   Rotation="-10"
                   AbsoluteLayout.LayoutBounds="0.05, 0.03, AutoSize, 45"/>

            <Image x:Name="topRightLogo" Style="{StaticResource CornerLogoStyle}"
                   Rotation="25" 
                   AbsoluteLayout.LayoutBounds="0.95,0.03, AutoSize, 45"/>

            <Image x:Name="bottomLeftLogo" Style="{StaticResource CornerLogoStyle}"
                   Rotation="210"
                   AbsoluteLayout.LayoutBounds="0.05,0.97,AutoSize,45"/>

            <Image x:Name="bottomRightLogo" Style="{StaticResource CornerLogoStyle}"
                   Rotation="-195"
                   AbsoluteLayout.LayoutBounds="0.95,0.97,AutoSize,45"/>

            <StackLayout Padding="5" AbsoluteLayout.LayoutFlags="PositionProportional"
                         x:Name="countLayout" Spacing="20"
                         AbsoluteLayout.LayoutBounds="0.5,0.5">
                <Label x:Name="roundCount" 
                       Text="Round 1"
                       FontFamily="Michroma-Regular"
                       TextColor="{DynamicResource PrimaryRed}"
                       FontSize="Large"
                       HorizontalTextAlignment="Center" VerticalTextAlignment="End">
                    <Label.Shadow>
                        <Shadow Brush="{DynamicResource GlowRed}"  
                                Offset="0,0" 
                                Radius="10" 
                                Opacity="0.6"/>
                    </Label.Shadow> 
                </Label>
                <Label x:Name="timerDisplay" TextColor="{DynamicResource PrimaryRed}"
                       FontFamily="Michroma-Regular"
                       FontSize="60"
                       Text="2:59">
                    <Label.Shadow>
                        <Shadow Brush="{DynamicResource GlowRed}" 
                                Offset="0,0" 
                                Radius="15"
                                Opacity="0.8"/>
                    </Label.Shadow>
                </Label>

            </StackLayout>
            <Label x:Name="tick"
                   AbsoluteLayout.LayoutFlags="PositionProportional"
                   AbsoluteLayout.LayoutBounds="0.5,0.5"
                   Text="1"
                   FontFamily="Michroma-Regular"
                   TextColor="{DynamicResource PrimaryRed}"
                   FontSize="80"
                   IsVisible="False"/>
            <StackLayout Orientation="Horizontal" x:Name="timerButtons"
                         AbsoluteLayout.LayoutFlags="PositionProportional"
                         AbsoluteLayout.LayoutBounds="0.5,0.85">
                <Button Style="{DynamicResource ActionButton}" 
                        x:Name="start" 
                        Text="START"
                        Command="{Binding StartCommand}"
                        IsVisible="{Binding IsStartButtonVisible}"
                        IsEnabled="{Binding IsStartButtonEnabled}"/>

                <Button Style="{DynamicResource ActionButton}"
                        x:Name="reset"
                        Text="RESET"
                        Command="{Binding ResetCommand}"
                        IsVisible="{Binding IsResetButtonVisible}"
                        IsEnabled="{Binding IsResetButtonEnabled}"/>

            </StackLayout>
            <Button Style="{DynamicResource ActionButton}" 
                    x:Name="stop"
                    Text="STOP"
                    AbsoluteLayout.LayoutBounds="0.5,0.85"
                    AbsoluteLayout.LayoutFlags="PositionProportional"
                    Command="{Binding StopCommand}"
                    IsVisible="{Binding IsStopButtonVisible}"
                    IsEnabled="{Binding IsStopButtonEnabled}"/>
            <Image x:Name="gear"
                   Source="gear.png"
                   AbsoluteLayout.LayoutFlags="PositionProportional"
                   AbsoluteLayout.LayoutBounds="0.5, 0.95,AutoSize,40"
                   IsEnabled="{Binding IsGearEnabled}">
            <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                </Image.GestureRecognizers>
            </Image>
            <!-- Overlay Carousel -->
            
        </AbsoluteLayout>
        <views:SettingsCarousel Grid.RowSpan="2" x:Name="settingsCarousel" 
                      IsVisible="{Binding IsOverlayVisible}"
                      BindingContext="{Binding .}"/>
    </Grid>

</ContentPage>
